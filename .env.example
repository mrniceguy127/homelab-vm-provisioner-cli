# Environment configuration for homelab-vm-provisioner-cli (Python CLI)
# Copy this file to .env and customize as needed
# Parent .env variables are loaded first, then these override them

# Virtual environment path
# Defaults to .venv in this directory if not set
# PROVISIONER_VENV_DIR=/custom/path/to/.venv

# Provisioner data directory
# Relative paths resolve from this CLI directory
# Defaults to ./data
# PROVISIONER_DATA_DIR=data

# Network configuration
# HLVMP_NETWORK_POOL_CIDR=10.80.0.0/16
# HLVMP_NETWORK_GROUP_PREFIX_LENGTH=28
