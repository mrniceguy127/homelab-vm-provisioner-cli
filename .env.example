# Environment configuration for homelab-vm-provisioner-cli (Python CLI)
# Copy this file to .env and customize as needed
# Parent workspace .env variables are loaded first, then these override them

# ==============================================================================
# Network Configuration
# ==============================================================================

# LOCAL_HOST: Default host/IP for service binding (inherited from parent)
# By default, scripts dynamically set this based on mode (localhost for native, 172.17.0.1 for Docker)
#LOCAL_HOST=localhost

# ==============================================================================
# Python Environment Configuration
# ==============================================================================

# Virtual environment path
# Defaults to .venv in this directory if not set
# PROVISIONER_VENV_DIR=/custom/path/to/.venv

# ==============================================================================
# Provisioner Data Configuration
# ==============================================================================

# Provisioner data directory
# Relative paths resolve from this CLI directory
# Defaults to ./data
# PROVISIONER_DATA_DIR=data

# ==============================================================================
# Network Configuration (VM provisioning)
# ==============================================================================

# Network pool configuration (optional)
# HLVMP_NETWORK_POOL_CIDR=10.80.0.0/16
# HLVMP_NETWORK_GROUP_PREFIX_LENGTH=28
