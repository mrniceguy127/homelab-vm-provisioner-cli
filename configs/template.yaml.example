# Copy this file to configs/<your-vm>.yaml and adjust the values.

vm:
  name: my-vm
  user: myuser
  # Optional but recommended when the tenant public key is already available.
  ssh_key_file: myuser.pub
  ram_mb: 4096
  vcpus: 2
  disk_gb: 40
  allow_sudo: false
  trust: untrusted
  template: base

paths:
  # Optional: override the default local VM data directory for this VM.
  # Relative paths resolve from the project root.
  # vm_data_dir: vm/data/my-vm

image:
  # Optional: override the guest cloud image or distro for this VM.
  # If url is set and name is omitted, the filename is derived from the URL.
  # url: https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img
  # os_variant: ubuntu24.04
  # name: noble-server-cloudimg-amd64.img

network:
  mode: nat-auto

  # For bridge mode, replace the block above with:
  # mode: bridge
  # bridge_name: br0

  # For a custom NAT subnet, replace the block above with:
  # mode: nat-custom
  # name: my-vm-net
  # zone: my-vm-zone
  # subnet_prefix: 192.168.240

packages:
  - htop
  - tmux

ports:
  - host: 2222
    guest: 22
    proto: tcp

  # Example web port forward:
  # - host: 8080
  #   guest: 80
  #   proto: tcp
