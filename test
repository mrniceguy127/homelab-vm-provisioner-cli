#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log() {
    printf '==> %s\n' "$*"
}

# Use the same approach as monorepo: redirect to temp file to avoid macOS password prompts
TEMP_OUTPUT=$(mktemp)
trap "rm -f '$TEMP_OUTPUT'" EXIT

# Temporarily disable errexit to capture exit codes
set +e

# Run tests with output buffered (prevents macOS password prompts in interactive terminals)
log "Running Ruff"
"$ROOT_DIR/scripts/lint" > "$TEMP_OUTPUT" 2>&1
LINT_EXIT=$?

log "Running Python tests with coverage"
"$ROOT_DIR/scripts/coverage" >> "$TEMP_OUTPUT" 2>&1
TEST_EXIT=$?

# Re-enable errexit
set -e

# Display buffered output
cat "$TEMP_OUTPUT"

# Check results
if [ $LINT_EXIT -ne 0 ] || [ $TEST_EXIT -ne 0 ]; then
    printf 'Verification failed. If this is a fresh checkout, run ./setup --dev first.\n' >&2
    exit 1
fi

log "Full verification complete"
