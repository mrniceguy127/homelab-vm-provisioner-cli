#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COVERAGE_DIR="$ROOT_DIR/.build/coverage"

source "$ROOT_DIR/scripts/_resolve_python.sh"
resolve_python_env

if ! "$PYTHON_BIN" -m coverage --version >/dev/null 2>&1; then
    printf 'Coverage is unavailable for interpreter %s. Run ./setup --dev or set PYTHON_BIN.\n' "$PYTHON_BIN" >&2
    exit 1
fi

# Run linting before tests
if ! "$PYTHON_BIN" -m ruff --version >/dev/null 2>&1; then
    printf 'Warning: Ruff is unavailable. Run ./setup --dev or set PYTHON_BIN to a dev interpreter.\n' >&2
else
    "$PYTHON_BIN" -m ruff check "$ROOT_DIR/homelab_vm_provisioner" "$ROOT_DIR/tests" || exit 1
fi

mkdir -p "$COVERAGE_DIR"
export COVERAGE_FILE="$COVERAGE_DIR/.coverage"

# Run tests with coverage, but continue even if tests fail to generate coverage report
TEST_EXIT_CODE=0
"$PYTHON_BIN" -m coverage run --rcfile "$ROOT_DIR/pyproject.toml" -m unittest tests.test_integration tests.test_config tests.test_provision tests.test_adapters tests.test_services tests.test_managed_nftables tests.test_reconciler tests.test_main tests.test_network tests.test_system tests.test_cli tests.test_constants tests.test_runtime_observation tests.test_service_workflows tests.test_snapshot_service tests.test_reconciler_helpers tests.test_service_mode tests.test_core || TEST_EXIT_CODE=$?

# Always generate coverage reports
"$PYTHON_BIN" -m coverage report --rcfile "$ROOT_DIR/pyproject.toml"
"$PYTHON_BIN" -m coverage html --rcfile "$ROOT_DIR/pyproject.toml" -d "$COVERAGE_DIR/html"
"$PYTHON_BIN" -m coverage xml --rcfile "$ROOT_DIR/pyproject.toml" -o "$COVERAGE_DIR/coverage.xml"

# Exit with the test exit code
exit $TEST_EXIT_CODE
