#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -x "$ROOT_DIR/.venv/bin/ruff" ]]; then
    exec "$ROOT_DIR/.venv/bin/ruff" check "$ROOT_DIR/homelab_vm_provisioner" "$ROOT_DIR/tests"
fi

source "$ROOT_DIR/scripts/_resolve_python.sh"
resolve_python_env

if ! "$PYTHON_BIN" -m ruff --version >/dev/null 2>&1; then
    printf 'Ruff is unavailable for interpreter %s. Run ./setup --dev on this machine or set PYTHON_BIN to a dev interpreter.\n' "$PYTHON_BIN" >&2
    exit 1
fi

exec "$PYTHON_BIN" -m ruff check "$ROOT_DIR/homelab_vm_provisioner" "$ROOT_DIR/tests"
