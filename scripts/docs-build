#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$ROOT_DIR/scripts/_resolve_python.sh"
resolve_python_env

if ! "$PYTHON_BIN" -m sphinx --version >/dev/null 2>&1; then
    printf 'Sphinx is unavailable for interpreter %s. Run ./setup --dev or set PYTHON_BIN.\n' "$PYTHON_BIN" >&2
    exit 1
fi

exec "$PYTHON_BIN" -m sphinx -b html "$ROOT_DIR/docs" "$ROOT_DIR/docs/_build/html"
