#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$ROOT_DIR/scripts/_resolve_python.sh"
resolve_python_env

if ! "$PYTHON_BIN" -c "import yaml" >/dev/null 2>&1; then
    printf 'Interpreter %s cannot import repo test dependencies. Run ./setup --dev or set PYTHON_BIN.\n' "$PYTHON_BIN" >&2
    exit 1
fi

exec "$PYTHON_BIN" -m unittest tests.test_config tests.test_provision tests.test_managed_nftables tests.test_reconciler tests.test_main tests.test_network tests.test_system tests.test_cli tests.test_integration
